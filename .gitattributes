# Normalize line endings so re-running the converter (scripts write LF) never
# shows a spurious CRLF<->LF diff on otherwise-unchanged files.
*.mdx   text eol=lf
*.md    text eol=lf
*.mjs   text eol=lf
*.js    text eol=lf
*.py    text eol=lf
*.json  text eol=lf

# Binary assets — never touch line endings / never diff
*.doc   binary
*.docx  binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
